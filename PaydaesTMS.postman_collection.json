    {
      "name": "CoreHR — Employees",
      "description": "All requests require X-Client-Id and X-Company-Id headers. CoreHR routes each request to the correct tenant database based on these values.",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-Client-Id",   "value": "{{client_id}}" },
              { "key": "X-Company-Id",  "value": "{{company_id}}" }
            ],
            "url": {
              "raw": "{{corehr_base_url}}/api/corehr/employees",
              "host": ["{{corehr_base_url}}"],
              "path": ["api", "corehr", "employees"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"EMP-001\",\n  \"firstName\": \"Ahmad\",\n  \"lastName\": \"Razif\",\n  \"email\": \"ahmad.razif@acme.com\",\n  \"phoneNumber\": \"+60112345678\",\n  \"hireDate\": \"2024-01-15\",\n  \"jobTitle\": \"Software Engineer\",\n  \"department\": \"Engineering\",\n  \"salary\": 8500.00\n}",
