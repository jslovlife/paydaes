{
  "info": {
    "name": "Paydaes API",
    "description": "Covers TMS (Tenant Management Service) and CoreHR (Employee, Leave Types, Public Holidays). CoreHR requires X-Client-Id and X-Company-Id headers on every request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "tms_base_url",   "value": "http://localhost:8081", "type": "string" },
    { "key": "corehr_base_url","value": "http://localhost:8082", "type": "string" },
    { "key": "client_id",      "value": "1",                    "type": "string" },
    { "key": "company_id",     "value": "1",                    "type": "string" }
  ],
  "item": [
    {
      "name": "TMS — Clients",
      "item": [
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation\",\n  \"email\": \"admin@acme.com\",\n  \"phoneNumber\": \"+60123456789\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Clients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients"]
            }
          }
        },
        {
          "name": "Get Client by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients/{{client_id}}",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients", "{{client_id}}"]
            }
          }
        },
        {
          "name": "Get Client by Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients/email/admin@acme.com",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients", "email", "admin@acme.com"]
            }
          }
        },
        {
          "name": "Search Clients by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients/search?name=Acme",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients", "search"],
              "query": [{ "key": "name", "value": "Acme" }]
            }
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients/{{client_id}}",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients", "{{client_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation Updated\",\n  \"email\": \"admin@acme.com\",\n  \"phoneNumber\": \"+60199999999\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients/{{client_id}}",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients", "{{client_id}}"]
            }
          }
        },
        {
          "name": "Get Total Client Count",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{tms_base_url}}/api/tms/clients/count",
              "host": ["{{tms_base_url}}"],
              "path": ["api", "tms", "clients", "count"]
            }
          }
        }
      ]
    },
